# =====================================================================
# Kids & Teens Medical Group — healow / eClinicalWorks integration.
# Copy this file to `.env.local` for local dev, and set the same keys in
# Vercel → Project → Settings → Environment Variables for production.
#
# ⚠️ The defaults baked into the code are PLACEHOLDERS from the prototype.
#    Get the REAL practice endpoints from Kids & Teens before launch.
# All keys are NEXT_PUBLIC_* because the links are used in the browser.
# =====================================================================

NEXT_PUBLIC_HEALOW_OPEN_ACCESS=https://healow.com/apps/practice/kids-and-teens-medical-group
NEXT_PUBLIC_PATIENT_PORTAL=https://healow.com/apps/jsp/webview/index.jsp
NEXT_PUBLIC_PAY_ONLINE=https://healow.com/apps/jsp/webview/index.jsp
NEXT_PUBLIC_FIND_DOCTOR=https://healow.com/apps/jsp/webview/index.jsp
NEXT_PUBLIC_MED_REFILLS=https://healow.com/apps/jsp/webview/index.jsp
NEXT_PUBLIC_LAB_RESULTS=https://healow.com/apps/jsp/webview/index.jsp
NEXT_PUBLIC_REFERRALS=https://healow.com/apps/jsp/webview/index.jsp
NEXT_PUBLIC_PRACTICE_CODE=KTMGLA
